{
  "name": "onstell-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Onstell cross-platform software KVM workspace.",
  "workspaces": [
    "apps/desktop"
  ],
  "scripts": {
    "dev": "npm --workspace apps/desktop run dev",
    "build": "npm --workspace apps/desktop run build",
    "tauri:dev": "npm --workspace apps/desktop run tauri:dev",
    "tauri:build": "npm --workspace apps/desktop run tauri:build",
    "check": "npm --workspace apps/desktop run check && npm run test:input-events && npm run test:permissions && npm run test:routing && npm run test:pointer-edge && npm run test:input-guard && npm run test:loopback",
    "test:input-events": "node scripts/run-input-event-tests.mjs",
    "test:permissions": "node scripts/run-permission-tests.mjs",
    "test:routing": "node scripts/run-routing-tests.mjs",
    "test:pointer-edge": "node scripts/run-pointer-edge-tests.mjs",
    "test:input-guard": "node scripts/run-input-guard-tests.mjs",
    "test:loopback": "node scripts/run-loopback-tests.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
