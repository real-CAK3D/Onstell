{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Onstell",
  "version": "0.1.0",
  "identifier": "com.onstell.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Onstell",
        "label": "main",
        "width": 460,
        "height": 260,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Cross-platform software KVM widget",
    "longDescription": "Onstell is an early-stage cross-platform software KVM for arranging physical computers like one coordinated display layout."
  }
}

